# Copy this file to .env and fill in your values
# MT5 terminal ID (the folder name under AppData/Roaming/MetaQuotes/Terminal/)
MT5_TERMINAL_ID=YOUR_TERMINAL_ID_HERE

# Full path to your MT5 terminal log directory (optional, auto-derived from MT5_TERMINAL_ID if not set)
# MT5_LOG_DIR=C:/Users/yourname/AppData/Roaming/MetaQuotes/Terminal/YOUR_TERMINAL_ID/logs

# Port to run the dashboard on (default: 8100)
PORT=8100

# Telegram bot token and chat ID for alerts
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Discord webhook URL for alerts (optional, fallback if Telegram not configured)
DISCORD_WEBHOOK=
